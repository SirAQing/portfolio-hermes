# ════════════════════════════════════════════════
# Hermes Chat Backend Configuration
# Copy to .env and fill in real values before `docker compose up -d`
# ════════════════════════════════════════════════

# ── DeepSeek LLM API ──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Embedding API (RAG) ──
# Default uses SiliconFlow's bge-large-zh. Reuse DEEPSEEK_API_KEY if provider matches.
EMBEDDING_API_KEY=sk-your-embedding-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_MAX_TOKENS=512
EMBEDDING_BATCH_SIZE=16

# ── RAG chunking & retrieval ──
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RAG_TOP_K=30
RAG_FINAL_K=5
RRF_K=60
RRF_VECTOR_WEIGHT=1.0
RRF_KEYWORD_WEIGHT=1.0

# ── Feishu (Lark) bot webhook ──
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# ── PushPlus (WeChat push) ──
PUSHPLUS_TOKEN=

# ── Notification schedule & urgent keywords ──
SUMMARY_SCHEDULE_HOURS=8,12,17
URGENT_KEYWORDS=人工,联系本人,真人,urgent,human,person

# ── CORS ──
# Allow-all mode (default) is fine for public portfolio.
# For strict allow-list: set CORS_ALLOW_ALL=false and provide CORS_ORIGINS.
CORS_ALLOW_ALL=true
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000

# ── Database ──
# In Docker, this is overridden by docker-compose to /app/data/hermes.db
DATABASE_PATH=hermes.db

# ── Auth / JWT ──
# Leave empty to auto-generate a random secret on each startup (not recommended for production).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Owner account (auto-created on first startup) ──
OWNER_EMAIL=owner@example.com
OWNER_INITIAL_PASSWORD=changeme123

# ── Guest quota (per IP per day) ──
GUEST_DAILY_LIMIT=5
