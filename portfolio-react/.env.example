# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 飞书群机器人 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# PushPlus Token (pushplus.plus 注册获取，用于微信推送)
PUSHPLUS_TOKEN=your-pushplus-token

# 通知设置
SUMMARY_SCHEDULE_HOURS=8,12,17
URGENT_KEYWORDS=人工,联系本人,真人,urgent,human,person

# CORS — default is allow-all for public deployments.
# Set CORS_ALLOW_ALL=false and provide CORS_ORIGINS to enable a strict allow-list.
CORS_ALLOW_ALL=true
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000

# 数据库
DATABASE_PATH=hermes.db
